# =============================================================================
# IntelliPlant Agent 1 - .gitignore
# =============================================================================

# --- Environment / secrets ---------------------------------------------------
.env
.env.*
!.env.example

# --- Python -------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# --- Virtual environments ------------------------------------------------------
venv/
env/
ENV/
.venv/

# --- Testing / coverage ---------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.cache
nosetests.xml
coverage.xml
*.cover

# --- Type checkers / linters -------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/

# --- Application runtime data (recreated automatically, never commit) -----------------
data/
data/chroma_store/
data/uploads/
logs/
*.log

# --- Local databases ------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
test.db
test_*.db

# --- Alembic (keep migration scripts, ignore nothing extra here by default) -----------
# alembic/versions/*.pyc is already covered by the Python rule above.

# --- IDE / editor ------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- Jupyter (in case of exploratory notebooks) --------------------------------------------
.ipynb_checkpoints/

# --- OS artifacts ---------------------------------------------------------------------------
Thumbs.db